# Background positions
bg_y1 = 0
bg_y2 = -HEIGHT
bg_scroll_speed = 3

# Player setup
player_width, player_height = 40, 40
player_x = WIDTH // 2 - player_width // 2
player_y = HEIGHT - 80
player_speed = 5

def draw_window():
    # Draw scrolling background
    win.blit(bg, (0, bg_y1))
    win.blit(bg, (0, bg_y2))

    # Draw player
    pygame.draw.rect(win, (255, 0, 0), (player_x, player_y, player_width, player_height))

